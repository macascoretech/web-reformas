---
import { SITE } from "@/config/site";

const currentYear = new Date().getFullYear();

const links = [
    { label: "Inicio", href: "/#inicio" },
    { label: "Nosotros", href: "/#nosotros" },
    { label: "Servicios", href: "/#servicios" },
    { label: "Proceso", href: "/#proceso" },
    { label: "Proyectos", href: "/#proyectos" },
    { label: "Contacto", href: "/#contacto" },
];

const legalLinks = [
    { label: "Aviso legal", href: "/aviso-legal" },
    { label: "Política de privacidad", href: "/politica-privacidad" },
    { label: "Política de cookies", href: "/politica-cookies" },
];
---

<footer class="bg-primary text-white" aria-label="Pie de página">
    <!-- Banda superior -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
            <!-- Branding -->
            <div class="sm:col-span-2 lg:col-span-1">
                <a
                    href="/#inicio"
                    class="flex items-center gap-3 mb-4 w-fit group"
                >
                    <div
                        class="w-10 h-10 bg-accent rounded-lg flex items-center justify-center flex-shrink-0"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="w-6 h-6 text-white"
                            aria-hidden="true"
                        >
                            <path
                                d="M11.47 3.84a.75.75 0 011.06 0l8.69 8.69a.75.75 0 101.06-1.06l-8.689-8.69a2.25 2.25 0 00-3.182 0l-8.69 8.69a.75.75 0 001.061 1.06l8.69-8.69z"
                            ></path>
                            <path
                                d="M12 5.432l8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 01-.75-.75v-4.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21a.75.75 0 01-.75.75H5.625a1.875 1.875 0 01-1.875-1.875v-6.198a2.29 2.29 0 00.091-.086L12 5.43z"
                            ></path>
                        </svg>
                    </div>
                    <span class="font-bold text-lg">{SITE.shortName}</span>
                </a>
                <p class="text-white/60 text-sm leading-relaxed mb-6">
                    Empresa familiar especializada en reformas integrales y
                    construcción de piscinas en la provincia de Murcia. Calidad,
                    cercanía y compromiso desde {SITE.foundingYear}.
                </p>

                <!-- Redes sociales -->
                <div class="flex gap-3" aria-label="Redes sociales">
                    {
                        SITE.social.instagram && (
                            <a
                                href={SITE.social.instagram}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="w-9 h-9 bg-white/10 hover:bg-accent rounded-lg flex items-center justify-center transition-colors duration-200"
                                aria-label="Instagram de Macas Core Build"
                            >
                                <svg
                                    viewBox="0 0 24 24"
                                    class="h-4 w-4 fill-current"
                                    aria-hidden="true"
                                >
                                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                                </svg>
                            </a>
                        )
                    }
                    <!-- WhatsApp -->
                    <a
                        href={`https://wa.me/${SITE.whatsapp}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-9 h-9 bg-white/10 hover:bg-green-600 rounded-lg flex items-center justify-center transition-colors duration-200"
                        aria-label="WhatsApp de Macas Core Build"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            class="h-4 w-4 fill-current"
                            aria-hidden="true"
                        >
                            <path
                                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Navegación -->
            <nav aria-label="Mapa del sitio">
                <h3
                    class="font-bold text-sm uppercase tracking-wider text-white/50 mb-4"
                >
                    Navegación
                </h3>
                <ul class="space-y-2.5" role="list">
                    {
                        links.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-white/70 hover:text-accent text-sm transition-colors duration-200 flex items-center gap-2 group"
                                >
                                    <span
                                        class="w-1 h-1 rounded-full bg-accent/50 group-hover:bg-accent transition-colors"
                                        aria-hidden="true"
                                    />
                                    {link.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>

            <!-- Legal -->
            <nav aria-label="Páginas legales">
                <h3
                    class="font-bold text-sm uppercase tracking-wider text-white/50 mb-4"
                >
                    Legal
                </h3>
                <ul class="space-y-2.5" role="list">
                    {
                        legalLinks.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-white/70 hover:text-accent text-sm transition-colors duration-200 flex items-center gap-2 group"
                                >
                                    <span
                                        class="w-1 h-1 rounded-full bg-accent/50 group-hover:bg-accent transition-colors"
                                        aria-hidden="true"
                                    />
                                    {link.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>

            <!-- Contacto rápido -->
            <address class="not-italic">
                <h3
                    class="font-bold text-sm uppercase tracking-wider text-white/50 mb-4"
                >
                    Contacto directo
                </h3>
                <ul class="space-y-3 text-sm" role="list">
                    <li>
                        <a
                            href={`tel:${SITE.phone}`}
                            class="flex items-center gap-2.5 text-white/70 hover:text-accent transition-colors group"
                            aria-label={`Llamar al ${SITE.phoneDisplay}`}
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-4 w-4 text-accent flex-shrink-0"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                                aria-hidden="true"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                ></path>
                            </svg>
                            {SITE.phoneDisplay}
                        </a>
                    </li>
                    <li>
                        <a
                            href={`mailto:${SITE.email}`}
                            class="flex items-center gap-2.5 text-white/70 hover:text-accent transition-colors group break-all"
                            aria-label={`Email: ${SITE.email}`}
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-4 w-4 text-accent flex-shrink-0"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                                aria-hidden="true"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                ></path>
                            </svg>
                            {SITE.email}
                        </a>
                    </li>
                    <li class="flex items-start gap-2.5 text-white/70">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-4 w-4 text-accent flex-shrink-0 mt-0.5"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                            aria-hidden="true"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <span>{SITE.address}</span>
                    </li>
                </ul>
            </address>
        </div>
    </div>

    <!-- Banda inferior -->
    <div class="border-t border-white/10">
        <div
            class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/40"
        >
            <p>
                &copy; {currentYear}
                {SITE.name} · CIF {SITE.cif} · Todos los derechos reservados.
            </p>
            <p>
                Desarrollado con
                <span aria-label="amor" role="img">♥</span>
                by <a
                    href="https://www.linkedin.com/in/zonydev/"
                    target="_blank"
                    rel="noopener noreferrer">ZonyDev</a
                >.
            </p>
        </div>
    </div>
</footer>
