    },
    {
        label: "Electricidad",
        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
    },
    {
        label: "Servicio manitas",
        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
    },
];
---

<section
    id="servicios"
    class="py-24 bg-light overflow-hidden"
    aria-labelledby="services-title"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Cabecera -->
        <div class="text-center mb-16 reveal">
            <span
                class="inline-block bg-accent/10 text-accent text-sm font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4"
            >
                Nuestros servicios
            </span>
            <h2
                id="services-title"
                class="text-3xl sm:text-4xl lg:text-5xl font-black text-primary mb-5"
            >
                Todo lo que necesita<br class="hidden sm:block" />
                <span class="text-accent">tu hogar y jardín</span>
            </h2>
            <p class="text-secondary text-lg max-w-2xl mx-auto leading-relaxed">
                Desde una pequeña reparación hasta la construcción completa de
                tu piscina soñada. Un único equipo de confianza para todos tus
                proyectos.
            </p>
        </div>

        <!-- Grid de servicios -->
        <div
            class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16"
            role="list"
            aria-label="Lista de servicios"
        >
            {
                services.map((service, i) => (
                    <article
                        class={`reveal group relative rounded-2xl p-7 flex flex-col gap-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl cursor-default ${
                            service.featured
                                ? "bg-primary text-white shadow-lg"
                                : "bg-white border border-gray-100 hover:border-accent/20"
                        }`}
                        style={`animation-delay: ${(i % 6) * 0.08}s`}
                        role="listitem"
                    >
                        {service.featured && (
                            <div class="absolute top-4 right-4">
                                <span class="bg-accent text-white text-xs font-semibold px-2.5 py-1 rounded-full">
                                    Destacado
                                </span>
                            </div>
                        )}
                        <div
                            class={`w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 ${
                                service.featured
                                    ? "bg-white/15"
                                    : "bg-accent/10"
                            }`}
                            aria-hidden="true"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class={`h-6 w-6 ${service.featured ? "text-accent" : "text-accent"}`}
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="1.8"
                                aria-hidden="true"
                            >
                                <Fragment set:html={service.icon} />
                            </svg>
                        </div>
                        <div>
                            <h3
                                class={`font-bold text-lg mb-2 ${service.featured ? "text-white" : "text-primary"}`}
                            >
                                {service.title}
                            </h3>
                            <p
                                class={`text-sm leading-relaxed ${service.featured ? "text-white/75" : "text-secondary"}`}
                            >
                                {service.description}
                            </p>
                        </div>
                    </article>
                ))
            }
        </div>

        <!-- Capacidades -->
        <div
            class="reveal bg-white rounded-2xl p-8 shadow-sm border border-gray-100"
        >
            <h3 class="text-xl font-bold text-primary text-center mb-6">
                Capacidades internas de nuestro equipo
            </h3>
            <div
                class="flex flex-wrap justify-center gap-4"
                role="list"
                aria-label="Especialidades del equipo"
            >
                {
                    capabilities.map((cap) => (
                        <div
                            class="flex items-center gap-2.5 bg-light hover:bg-accent/10 text-primary px-5 py-3 rounded-xl font-medium text-sm transition-colors duration-200 border border-gray-100 hover:border-accent/20"
                            role="listitem"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-4 w-4 text-accent"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                                aria-hidden="true"
                            >
                                <Fragment set:html={cap.icon} />
                            </svg>
                            {cap.label}
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>
