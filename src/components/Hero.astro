---
import { SITE } from "@/config/site";
import { Image } from "astro:assets";
import hero from "../assets/hero-bg.webp";
---

<section
    id="inicio"
    class="relative min-h-screen flex items-center justify-center overflow-hidden"
    aria-label="Presentación de la empresa"
>
    <div class="absolute inset-0 z-0" aria-hidden="true">
        <Image
            src={hero}
            alt=""
            class="w-full h-full object-cover"
            widths={[640, 1024, 1920]}
            format={"webp"}
            quality={80}
            loading="eager"
            fetchpriority="high"
        />
        <!-- Overlay degradado -->
        <div
            class="absolute inset-0 bg-gradient-to-r from-primary/90 via-primary/75 to-primary/40"
        >
        </div>
    </div>

    <!-- Partículas decorativas -->
    <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
        <div
            class="absolute top-20 right-1/4 w-64 h-64 bg-accent/10 rounded-full blur-3xl"
        >
        </div>
        <div
            class="absolute bottom-20 left-1/3 w-96 h-96 bg-secondary/20 rounded-full blur-3xl"
        >
        </div>
    </div>

    <div
        class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 pt-40"
    >
        <div class="max-w-3xl">
            <!-- Badge -->
            <div
                class="inline-flex items-center gap-2 bg-accent/20 border border-accent/40 text-amber-300 text-sm font-medium px-4 py-1.5 rounded-full mb-6 animate-fade-in"
                aria-label="Empresa ubicada en Molina de Segura, Murcia"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    ></path>
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                Molina de Segura, Murcia
            </div>

            <!-- Título principal -->
            <h1
                class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-5 animate-fade-in-up"
                style="animation-delay: 0.1s; animation-fill-mode: backwards;"
            >
                Reformas y piscinas<br />
                <span class="text-accent">hechas a medida</span><br />
                para tu hogar
            </h1>

            <!-- Eslogan -->
            <p
                class="text-lg sm:text-xl text-white/80 font-light mb-8 max-w-xl leading-relaxed animate-fade-in-up"
                style="animation-delay: 0.25s; animation-fill-mode: backwards;"
            >
                {SITE.slogan} Empresa familiar con profesionales comprometidos con
                cada detalle de tu proyecto.
            </p>

            <!-- CTA Buttons -->
            <div
                class="flex flex-col sm:flex-row gap-4 animate-fade-in-up"
                style="animation-delay: 0.4s; animation-fill-mode: backwards;"
            >
                <a
                    href="#contacto"
                    class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-amber-600 text-white font-semibold px-8 py-4 rounded-xl text-base transition-all duration-200 shadow-lg hover:shadow-accent/40 hover:-translate-y-1"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-5 w-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                        aria-hidden="true"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                        ></path>
                    </svg>
                    Solicitar presupuesto gratis
                </a>

                <a
                    href={`https://wa.me/${SITE.whatsapp}?text=Hola%2C%20me%20gustar%C3%ADa%20solicitar%20informaci%C3%B3n%20sobre%20sus%20servicios.`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center gap-2 bg-white/15 hover:bg-white/25 border border-white/30 text-white font-semibold px-8 py-4 rounded-xl text-base transition-all duration-200 backdrop-blur-sm hover:-translate-y-1"
                    aria-label="Contactar por WhatsApp"
                >
                    <!-- WhatsApp SVG icon -->
                    <svg
                        viewBox="0 0 24 24"
                        class="h-5 w-5"
                        fill="currentColor"
                        aria-hidden="true"
                    >
                        <path
                            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                        ></path>
                    </svg>
                    WhatsApp directo
                </a>
            </div>

            <!-- Stats -->
            <div
                class="mt-14 flex flex-wrap gap-8 animate-fade-in-up"
                style="animation-delay: 0.55s; animation-fill-mode: backwards;"
                aria-label="Datos destacados de la empresa"
            >
                {
                    [
                        { value: "100%", label: "Satisfacción garantizada" },
                        { value: "+10", label: "Servicios especializados" },
                        { value: "Familiar", label: "Empresa de confianza" },
                    ].map((stat) => (
                        <div class="text-center sm:text-left">
                            <div class="text-3xl font-black text-accent">
                                {stat.value}
                            </div>
                            <div class="text-sm text-white/70 mt-0.5">
                                {stat.label}
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>

    <!-- Flecha scroll hacia abajo -->
    <!-- TODO: probar animate-bounce dentro de <div> -->
    <div
        class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10"
        aria-hidden="true"
    >
        <a
            href="#nosotros"
            class="text-white/50 hover:text-accent transition-colors"
            tabindex="-1"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-8 w-8"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
            >
                <title>Desplazarse hacia abajo</title>
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19 9l-7 7-7-7"></path>
            </svg>
        </a>
    </div>
</section>
