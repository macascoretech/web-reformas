<section
  id="proyectos"
  class="py-24 bg-white overflow-hidden"
  aria-labelledby="portfolio-title"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Cabecera -->
    <div class="text-center mb-16 reveal">
      <span
        class="inline-block bg-accent/10 text-accent text-sm font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4"
      >
        Nuestros proyectos
      </span>
      <h2
        id="portfolio-title"
        class="text-3xl sm:text-4xl lg:text-5xl font-black text-primary mb-5"
      >
        Trabajos que hablan<br class="hidden sm:block" />
        <span class="text-accent">por sí solos</span>
      </h2>
      <p class="text-secondary text-lg max-w-2xl mx-auto leading-relaxed">
        Cada proyecto es único y lo tratamos como tal. Aquí tienes una muestra
        de los trabajos que hemos realizado con orgullo en Murcia y alrededores.
      </p>
    </div>

    <!-- Próximamente -->
    <div class="flex flex-col items-center justify-center py-20 px-6 reveal">
      <div
        class="bg-light border border-gray-200 rounded-2xl shadow-sm max-w-xl w-full text-center px-10 py-14"
      >
        <div
          class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-accent/10 mb-6"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-8 w-8 text-accent"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"
            ></path>
          </svg>
        </div>
        <h3 class="text-2xl font-black text-primary mb-3">Próximamente</h3>
        <p class="text-secondary text-base leading-relaxed">
          Estamos recopilando nuestros mejores trabajos para mostrártelos aquí.
          <br class="hidden sm:block" />
          ¡Vuelve pronto para descubrir nuestros proyectos!
        </p>
      </div>
    </div>

    <!-- CARRUSEL (descomentar cuando haya proyectos) -->
