---
import { SITE } from "@/config/site";
---

<section
  id="contacto"
  class="py-24 bg-light overflow-hidden relative"
  aria-labelledby="contact-title"
>
  <!-- Decoración -->
  <div
    class="absolute inset-0 overflow-hidden pointer-events-none"
    aria-hidden="true"
  >
    <div
      class="absolute -top-20 -left-20 w-80 h-80 bg-accent/5 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute -bottom-20 -right-20 w-80 h-80 bg-primary/5 rounded-full blur-3xl"
    >
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Cabecera -->
    <div class="text-center mb-16 reveal">
      <span
        class="inline-block bg-accent/10 text-accent text-sm font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4"
      >
        Contacto
      </span>
      <h2
        id="contact-title"
        class="text-3xl sm:text-4xl lg:text-5xl font-black text-primary mb-5"
      >
        Cuéntanos tu proyecto.<br class="hidden sm:block" />
        <span class="text-accent">Presupuesto gratis</span>
      </h2>
      <p class="text-secondary text-lg max-w-2xl mx-auto">
        Nos pondremos en contacto contigo en menos de 24 horas laborables. Sin
        compromiso ninguno.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <!-- Datos de contacto -->
      <div class="space-y-8 reveal-left">
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <h3 class="text-xl font-bold text-primary mb-6">
            Información de contacto
          </h3>

          <div class="space-y-5">
            <!-- Teléfono -->
            <a
              href={`tel:${SITE.phone}`}
              class="flex items-center gap-4 group hover:text-accent transition-colors"
              aria-label={`Llamar al ${SITE.phoneDisplay}`}
            >
              <div
                class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-accent/20 transition-colors"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 text-accent"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-DEFAULT uppercase tracking-wide">
                  Teléfono
                </p>
                <p
                  class="font-semibold text-primary group-hover:text-accent transition-colors"
                >
                  {SITE.phoneDisplay}
                </p>
              </div>
            </a>

            <!-- WhatsApp -->
            <a
              href={`https://wa.me/${SITE.whatsapp}?text=Hola%2C%20me%20gustar%C3%ADa%20pedir%20informaci%C3%B3n%20sobre%20sus%20servicios.`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 group hover:text-green-600 transition-colors"
              aria-label="Contactar por WhatsApp"
            >
              <div
                class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-green-100 transition-colors"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5 text-green-600"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-DEFAULT uppercase tracking-wide">
                  WhatsApp
                </p>
                <p
                  class="font-semibold text-primary group-hover:text-green-600 transition-colors"
                >
                  Chatear ahora
                </p>
              </div>
            </a>

            <!-- Email -->
            <a
              href={`mailto:${SITE.email}`}
              class="flex items-center gap-4 group hover:text-accent transition-colors"
              aria-label={`Enviar email a ${SITE.email}`}
            >
              <div
                class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-accent/20 transition-colors"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 text-accent"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-DEFAULT uppercase tracking-wide">
                  Email
                </p>
                <p
                  class="font-semibold text-primary group-hover:text-accent transition-colors break-all"
                >
                  {SITE.email}
                </p>
              </div>
            </a>

            <!-- Dirección -->
            <div class="flex items-center gap-4">
              <div
                class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 text-accent"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-DEFAULT uppercase tracking-wide">
                  Zona de trabajo
                </p>
                <p class="font-semibold text-primary">Provincia de Murcia</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Horario -->
        <div class="bg-primary rounded-2xl p-6 text-white">
          <h3 class="font-bold text-base mb-4 flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 text-accent"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Horario de atención
          </h3>
          <dl class="space-y-2 text-sm">
            <div class="flex justify-between">
              <dt class="text-white/70">Lunes – Viernes</dt>
              <dd class="text-white font-medium">08:00 – 20:00</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-white/70">Sábado</dt>
              <dd class="text-white font-medium">09:00 – 14:00</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-white/70">Domingo</dt>
              <dd class="text-white/50">Cerrado</dd>
            </div>
          </dl>
          <p class="mt-4 text-white/60 text-xs">
            Fuera de horario puedes dejarnos un mensaje por WhatsApp o email.
          </p>
        </div>
      </div>

      <!-- Formulario -->
      <div class="reveal-right">
        <div class="bg-white rounded-2xl shadow-sm p-8">
          <h3 class="text-xl font-bold text-primary mb-6">
            Envíanos tu consulta
          </h3>

          <form
            id="contact-form"
            novalidate
            class="space-y-5"
            aria-label="Formulario de contacto"
          >
            <!-- Nombre -->
            <div>
              <label
                for="name"
                class="block text-sm font-medium text-primary mb-1.5"
              >
                Nombre completo <span class="text-red-500" aria-hidden="true"
                  >*</span
                >
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                aria-required="true"
                aria-describedby="name-error"
                placeholder="Tu nombre y apellidos"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-light text-primary placeholder-gray-DEFAULT/60 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all text-sm"
              />
              <p
                id="name-error"
                class="mt-1.5 text-xs text-red-500 hidden"
                role="alert"
                aria-live="polite"
              >
              </p>
            </div>

            <!-- Email -->
            <div>
              <label
                for="email"
                class="block text-sm font-medium text-primary mb-1.5"
              >
                Correo electrónico <span class="text-red-500" aria-hidden="true"
                  >*</span
                >
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                aria-required="true"
                aria-describedby="email-error"
                placeholder="tu@email.com"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-light text-primary placeholder-gray-DEFAULT/60 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all text-sm"
              />
              <p
                id="email-error"
                class="mt-1.5 text-xs text-red-500 hidden"
                role="alert"
                aria-live="polite"
              >
              </p>
            </div>

            <!-- Teléfono -->
            <div>
              <label
                for="phone"
                class="block text-sm font-medium text-primary mb-1.5"
              >
                Teléfono <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                autocomplete="tel"
                aria-required="true"
                aria-describedby="phone-error"
                placeholder="600 000 000"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-light text-primary placeholder-gray-DEFAULT/60 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all text-sm"
              />
              <p
                id="phone-error"
                class="mt-1.5 text-xs text-red-500 hidden"
                role="alert"
                aria-live="polite"
              >
              </p>
            </div>

            <!-- Mensaje -->
            <div>
              <label
                for="message"
                class="block text-sm font-medium text-primary mb-1.5"
              >
                Mensaje <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                aria-required="true"
                aria-describedby="message-error"
                placeholder="Cuéntanos qué necesitas: tipo de reforma, superficie aproximada, plazo deseado…"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-light text-primary placeholder-gray-DEFAULT/60 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all text-sm resize-none"
              ></textarea>
              <p
                id="message-error"
                class="mt-1.5 text-xs text-red-500 hidden"
                role="alert"
                aria-live="polite"
              >
              </p>
            </div>

            <!-- RGPD checkbox -->
            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="privacy"
                name="privacy"
                required
                aria-required="true"
                aria-describedby="privacy-error"
                class="mt-0.5 w-4 h-4 accent-accent border-gray-300 rounded flex-shrink-0"
              />
              <div>
                <label
                  for="privacy"
                  class="text-xs text-secondary leading-relaxed"
                >
                  He leído y acepto la
                  <a
                    href="/politica-privacidad"
                    class="text-accent hover:underline"
                    >política de privacidad</a
                  >. Los datos facilitados serán tratados exclusivamente para
                  gestionar tu consulta, de acuerdo con el Reglamento (UE)
                  2016/679 (RGPD).
                </label>
                <p
                  id="privacy-error"
                  class="mt-1 text-xs text-red-500 hidden"
                  role="alert"
                  aria-live="polite"
                >
                </p>
              </div>
            </div>

            <!-- Submit -->
            <button
              id="submit-btn"
              type="submit"
              class="w-full bg-accent hover:bg-amber-600 text-white font-semibold py-4 rounded-xl transition-all duration-200 shadow hover:shadow-lg hover:-translate-y-0.5 flex items-center justify-center gap-2 text-base disabled:opacity-60 disabled:cursor-not-allowed disabled:hover:translate-y-0"
            >
              <svg
                id="submit-icon"
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
              </svg>
              <span id="submit-text">Enviar consulta</span>
            </button>

            <p class="text-xs text-center text-gray-DEFAULT">
              * Campos obligatorios. Respuesta garantizada en menos de 24 h
              laborables.
            </p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Modal de confirmación -->
<div
  id="success-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <!-- Backdrop -->
  <div
    id="modal-backdrop"
    class="absolute inset-0 bg-primary/60 backdrop-blur-sm"
    aria-hidden="true"
  >
  </div>

  <!-- Contenido -->
  <div
    class="relative bg-white rounded-2xl shadow-2xl max-w-sm w-full p-8 text-center animate-fade-in-up"
  >
    <div
      class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-5"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-8 w-8 text-green-600"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"
        ></path>
      </svg>
    </div>
    <h2 id="modal-title" class="text-xl font-black text-primary mb-3">
      ¡Mensaje enviado!
    </h2>
    <p class="text-secondary text-sm leading-relaxed mb-6">
      Gracias por contactar con nosotros. Hemos recibido tu consulta y nos
      pondremos en contacto contigo lo antes posible.
    </p>
    <button
      id="modal-close"
      type="button"
      class="bg-accent hover:bg-amber-600 text-white font-semibold px-8 py-3 rounded-xl transition-colors w-full"
    >
      Cerrar
    </button>
  </div>
</div>

<!-- Modal de error -->
<div
  id="error-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="error-modal-title"
>
  <div
    class="absolute inset-0 bg-primary/60 backdrop-blur-sm"
    aria-hidden="true"
  >
  </div>
  <div
    class="relative bg-white rounded-2xl shadow-2xl max-w-sm w-full p-8 text-center animate-fade-in-up"
  >
    <div
      class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-5"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-8 w-8 text-red-600"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </div>
    <h2 id="error-modal-title" class="text-xl font-black text-primary mb-3">
      Algo salió mal
    </h2>
    <p class="text-secondary text-sm leading-relaxed mb-6">
      No pudimos enviar tu mensaje en este momento. Por favor, inténtalo de
      nuevo o contáctanos directamente por teléfono o WhatsApp.
    </p>
    <button
      id="error-modal-close"
      type="button"
      class="bg-primary hover:bg-primary/90 text-white font-semibold px-8 py-3 rounded-xl transition-colors w-full"
    >
      Cerrar
    </button>
  </div>
</div>

<script>
  // ── Helpers ──────────────────────────────────────────────────────
  function showError(inputId: string, message: string) {
    const input = document.getElementById(inputId) as HTMLInputElement;
    const errorEl = document.getElementById(`${inputId}-error`);
    input?.classList.add("border-red-400", "bg-red-50");
    input?.classList.remove("border-gray-200");
    if (errorEl) {
      errorEl.textContent = message;
      errorEl.classList.remove("hidden");
    }
  }

  function clearError(inputId: string) {
    const input = document.getElementById(inputId) as HTMLInputElement;
    const errorEl = document.getElementById(`${inputId}-error`);
    input?.classList.remove("border-red-400", "bg-red-50");
    input?.classList.add("border-gray-200");
    if (errorEl) {
      errorEl.textContent = "";
      errorEl.classList.add("hidden");
    }
  }

  function showModal(id: string) {
    const modal = document.getElementById(id);
    modal?.classList.remove("hidden");
    modal?.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function closeModal(id: string) {
    const modal = document.getElementById(id);
    modal?.classList.add("hidden");
    modal?.classList.remove("flex");
    document.body.style.overflow = "";
  }

  // ── Validación ───────────────────────────────────────────────────
  function validate(data: {
    name: string;
    email: string;
    phone: string;
    message: string;
    privacy: boolean;
  }): boolean {
    let valid = true;
    ["name", "email", "phone", "message", "privacy"].forEach((id) =>
      clearError(id),
    );

    if (!data.name.trim() || data.name.trim().length < 2) {
      showError("name", "Introduce tu nombre completo (mínimo 2 caracteres).");
      valid = false;
    }
    const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRe.test(data.email.trim())) {
      showError("email", "Introduce un correo electrónico válido.");
      valid = false;
    }
    const phoneRe = /^(\+34|0034|34)?[\s-]?[6789]\d{8}$/;
    if (!phoneRe.test(data.phone.replace(/\s/g, ""))) {
      showError("phone", "Introduce un número de teléfono español válido.");
      valid = false;
    }
    if (!data.message.trim() || data.message.trim().length < 10) {
      showError("message", "El mensaje debe tener al menos 10 caracteres.");
      valid = false;
    }
    if (!data.privacy) {
      showError(
        "privacy",
        "Debes aceptar la política de privacidad para continuar.",
      );
      valid = false;
    }
    return valid;
  }

  // ── Form submit ──────────────────────────────────────────────────
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const submitText = document.getElementById("submit-text");
  const submitIcon = document.getElementById("submit-icon");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const data = {
      name: (fd.get("name") as string) ?? "",
      email: (fd.get("email") as string) ?? "",
      phone: (fd.get("phone") as string) ?? "",
      message: (fd.get("message") as string) ?? "",
      privacy: !!fd.get("privacy"),
    };

    if (!validate(data)) return;

    // Loading state
    submitBtn.disabled = true;
    if (submitText) submitText.textContent = "Enviando…";
    if (submitIcon)
      submitIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />`;

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.reset();
        showModal("success-modal");
      } else {
        showModal("error-modal");
      }
    } catch {
      showModal("error-modal");
    } finally {
      submitBtn.disabled = false;
      if (submitText) submitText.textContent = "Enviar consulta";
      if (submitIcon)
        submitIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />`;
    }
  });

  // ── Cerrar modales ──────────────────────────────────────────────
  document
    .getElementById("modal-close")
    ?.addEventListener("click", () => closeModal("success-modal"));
  document
    .getElementById("error-modal-close")
    ?.addEventListener("click", () => closeModal("error-modal"));
  document
    .getElementById("modal-backdrop")
    ?.addEventListener("click", () => closeModal("success-modal"));

  // Cerrar con Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closeModal("success-modal");
      closeModal("error-modal");
    }
  });
</script>
