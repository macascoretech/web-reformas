# =============================================
# CONFIGURACIÓN DE RESEND (Email)
# =============================================
# Obtén tu API Key en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email del propietario donde llegará cada consulta
CONTACT_EMAIL=invented@mail.com

# Email remitente verificado en Resend (dominio verificado)
FROM_EMAIL=no-reply@mail.com

# (Opcional) Email en copia (CC) en la notificación al propietario
# Déjalo vacío o elimínalo si no necesitas copia
CC_EMAIL=

# =============================================
# CONFIGURACIÓN GENERAL DEL SITIO
# =============================================
# URL pública del sitio (sin barra final)
PUBLIC_SITE_URL=https://example.com
